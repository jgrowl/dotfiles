[Unit]
Description=Sway on tty1 for %I
After=systemd-user-sessions.service getty@tty1.service
Conflicts=getty@tty1.service

[Service]
User=%I
PAMName=login
WorkingDirectory=/home/%I

StandardInput=tty
StandardOutput=journal
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

ExecStart=/home/%I/.local/bin/sway-session

Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical.target

