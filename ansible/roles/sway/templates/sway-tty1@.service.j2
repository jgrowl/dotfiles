[Unit]
Description=Sway on tty1 for {{ sway_user }}
After=systemd-user-sessions.service
After=systemd-logind.service
After=getty@tty1.service
Requires=systemd-logind.service
Conflicts=getty@tty1.service
Wants=systemd-user-sessions.service

[Service]
User={{ sway_user }}
PAMName=login

WorkingDirectory=/home/{{ sway_user }}
Environment=HOME=/home/{{ sway_user }}

Environment=XDG_SESSION_TYPE=wayland
Environment=XDG_RUNTIME_DIR=/run/user/{{ sway_uid | default('1000') }}
Environment=XDG_CURRENT_DESKTOP=sway

#Environment=WLR_DRM_DEVICES=/dev/dri/card1:/dev/dri/card0
Environment=WLR_DRM_DEVICES=/dev/dri/card0

# This forces sway (wlroots) to use wlroots fulkan renderer
# Environment=WLR_RENDERER=vulkan

# This forces sway to use OPENGL ES
# Environment=WLR_RENDERER=gles2

# I am adding this to disable hardware cursors. I am trying to fix a bug where dkms turn off of screens causes a crash
Environment=WLR_NO_HARDWARE_CURSORS=1

# tie to real tty1
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
StandardInput=tty
StandardOutput=tty
StandardError=journal

# # use the var you defined
# ConditionPathExists={{ sway_session_path }}
# ExecStart={{ sway_session_path }}

# Directly start sway with your flag
# Unsupported seems to be necessary or else steam will crash out.
#ExecStart=/usr/bin/sway --unsupported-gpu
ExecStart=/usr/bin/sway

NoNewPrivileges=no

## Adding these to fix discord problems with bwrap.
## I cannot NoNewPrivileges=yes because then I can't sudo in terminals started by sway
#NoNewPrivileges=yes
#CapabilityBoundingSet=
#AmbientCapabilities=
AmbientCapabilities=
CapabilityBoundingSet=~CAP_WAKE_ALARM


Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
