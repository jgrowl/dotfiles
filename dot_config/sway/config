output HDMI-A-1 resolution 2560x1440 position 0,1080
workspace 3 output HDMI-A-1


#Output HDMI-A-1 'RST 1to4          0x00000001' (focused)

# DP-2 = Ancor Communications Inc VS278 (serial: FBLMQS084061)
output DP-2 resolution 1920x1080 position 3800,0
#output DP-2 resolution 1920x1080 position 1920,0
workspace 4 output DP-2
