#exec_always --no-startup-id /home/jon/.local/share/chezmoi/scripts/sway-assign.sh

#exec_always systemctl --user import-environment WAYLAND_DISPLAY XDG_RUNTIME_DIR XDG_SESSION_TYPE; systemctl --user restart swayidle.service
#exec_always systemctl --user import-environment WAYLAND_DISPLAY XDG_RUNTIME_DIR XDG_SESSION_TYPE; systemctl --user start swayidle.service

# This is necessary to ensure that sway is fully initialized. If this step is not done, then waybar will still load
# but it will be missing the display numbers.
# It might be worth setting RestartSec=2 or increase loop count in the script
#exec_always systemctl --user restart waybar.service

# Make Sway's env visible to systemd --user
#exec_always systemctl --user import-environment \
#  WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP XDG_SESSION_TYPE

exec_always {
    systemctl --user import-environment WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
    #systemctl --user start graphical-session.target
    systemctl --user restart graphical-session.target

    # Kick off your user-session target (waybar, clipman, etc. hang off this)
    #systemctl --user start sway-session.target
    systemctl --user restart sway-session.target

    systemctl --user restart swayidle.service
    systemctl --user restart waybar.service


    systemctl --user restart discord.service
    systemctl --user restart steam.service
}



