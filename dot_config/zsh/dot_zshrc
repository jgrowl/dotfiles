# To run ollama with GPU support, use the following alias.
# It is also important to unbind from vfio. Use script in scripts folder
# run `watch -n 1 nvidia-smi` to verify that GPU is being used.
ollama-run-gpu() {
  # Find the PID of 'ollama serve' run by your user
  pid=$(pgrep -u "$USER" -f "/usr/local/bin/ollama serve")

  # If found, kill it
  if [ -n "$pid" ]; then
    echo "Killing existing ollama serve process (PID $pid)..."
    kill "$pid"
    sleep 1
  fi

  # Start a new ollama run with GPU enabled
  echo "Starting ollama with GPU..."
  OLLAMA_USE_CUDA=1 OLLAMA_DEBUG=1 ollama run "$@"
}


