# This command just puts the outputs of the compiled code into a shared folder
# instead of the path in which the project resides
# Look in $HOME/.cargo-target
.cargo() {
  local root name slug
  root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  name="$(basename "$root")"
  # hash avoids collisions for same-named projects in different paths
  slug="${name}-$(printf '%s' "$root" | sha1sum | cut -c1-8)"
  CARGO_TARGET_DIR="$HOME/.cargo-target/$slug" command cargo "$@"
}

##  For getting filename/paths in titlebar under tmux.
function _title_precmd() {
  # If something (like nvim) sets a title, it will overwrite this while running.
  print -Pn "\e]0;%~\a"
}
precmd_functions+=(_title_precmd)


