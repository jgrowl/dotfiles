#!/usr/bin/env bash
set -euo pipefail

# Toggle Helvum patchbay
# - Works for Flatpak (org.pipewire.Helvum) or native 'helvum'

launch() {
  if command -v flatpak >/dev/null 2>&1 && flatpak info org.pipewire.Helvum >/dev/null 2>&1; then
    nohup flatpak run org.pipewire.Helvum >/dev/null 2>&1 &
  elif command -v helvum >/dev/null 2>&1; then
    nohup helvum >/dev/null 2>&1 &
  else
    echo "helvum not found (flatpak or native)" >&2
    exit 1
  fi
  disown
}

# Try to find an existing window via sway tree (best)
if command -v swaymsg >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  IDS="$(swaymsg -rt get_tree \
    | jq -r '
      .. | objects
      | select(
          (.app_id? // "" | ascii_downcase) as $id
          | ($id == "org.pipewire.helvum" or ($id | contains("helvum")))
          or
          ((.window_properties?.class? // "" | ascii_downcase) | contains("helvum"))
          or
          ((.name? // "" | ascii_downcase) | contains("helvum"))
        )
      | .id
    ')"
  if [[ -n "${IDS}" ]]; then
    while read -r id; do
      [[ -n "${id}" ]] && swaymsg "[con_id=${id}]" kill >/dev/null
    done <<< "${IDS}"
    exit 0
  fi
fi

# Fallback: toggle by process name
if pgrep -x helvum >/dev/null 2>&1; then
  pkill -x helvum
else
  launch
fi

